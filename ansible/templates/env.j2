DB_HOST={{ lookup('env', 'DB_HOST') | default('localhost') }}
DB_NAME={{ db_name }}
DB_USER={{ db_user }}
DB_PASS={{ db_password }}

SMTP_HOST={{ lookup('env', 'SMTP_HOST') | default('smtp.gmail.com') }}
SMTP_PORT={{ lookup('env', 'SMTP_PORT') | default('587') }}
SMTP_USER={{ lookup('env', 'SMTP_USER') }}
SMTP_PASS={{ lookup('env', 'SMTP_PASS') }}

APP_ENV={{ environment }}
APP_DEBUG={{ 'true' if environment == 'staging' else 'false' }}
APP_URL={{ lookup('env', 'APP_URL') }}

MAX_UPLOAD_SIZE=10M
UPLOAD_PATH=uploads/